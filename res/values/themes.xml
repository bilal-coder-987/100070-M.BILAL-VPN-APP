<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Bilal" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/vpnBlack</item>
        <item name="colorPrimaryVariant">@color/vpnBlack</item>
        <item name="colorSecondary">@color/vpnAccent</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/vpnBlack</item>
        <item name="android:windowBackground">@color/vpnBlack</item>

        <!-- Customize your theme here. -->
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>
    </style>

    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.BottomNavigationView</item>
        <item name="itemIconTint">@color/vpnGrey</item>
        <item name="itemTextColor">@color/vpnGrey</item>
        <item name="itemRippleColor">@color/vpnAccent</item>
    </style>

    <style name="ThemeOverlay.App.BottomNavigationView" parent="">
        <item name="colorPrimary">@color/vpnAccent</item>
    </style>
</resources>