<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/cardBackgroundColor"
    app:strokeWidth="1dp"
    app:strokeColor="@color/primaryLightColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monday"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/accentColor1"/>

        <View
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:background="@color/accentColor2"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_breakfast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Breakfast: Oatmeal"
                android:drawablePadding="12dp"
                android:textColor="@color/primaryTextColor"
                android:textSize="16sp"
                app:drawableStartCompat="@android:drawable/ic_menu_today"
                app:drawableTint="@color/primaryColor" />

            <TextView
                android:id="@+id/tv_lunch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Lunch: Chicken Salad"
                android:drawablePadding="12dp"
                android:textColor="@color/primaryTextColor"
                android:textSize="16sp"
                app:drawableStartCompat="@android:drawable/ic_menu_today"
                app:drawableTint="@color/accentColor1" />

            <TextView
                android:id="@+id/tv_dinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Dinner: Grilled Salmon"
                android:drawablePadding="12dp"
                android:textColor="@color/primaryTextColor"
                android:textSize="16sp"
                app:drawableStartCompat="@android:drawable/ic_menu_today"
                app:drawableTint="@color/accentColor3" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>